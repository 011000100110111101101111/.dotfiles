#!/usr/bin/env bash

killall eww -9
eww daemon
eww open-many \
	today \
	assistant \
	workspaces computer \
	music albumArt dunst

glava -e "radial_rc.glsl" &
disown

hyprctl dispatch workspace 6
layout -n 6
sleep 2
layout -n 1
sleep 2
dunstify -a "attention" -u low "$USER@$HOSTNAME" "Welcome back にちは"
